@{
    ViewData["Title"] = "Student Portal";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Students Portal</title>

    <style>
        body {
            font-family: Arial;
            background-color: #f4f6f9;
            margin: 0;
        }

        .header {
            background-color: #0078D7;
            color: white;
            padding: 15px;
            text-align: center;
        }

        .container {
            margin: 30px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 2px 10px rgba(0,0,0,0.1);
            margin-bottom: 20px;
        }

        .btn {
            display: inline-block;
            padding: 10px 15px;
            background: #28a745;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .footer {
            text-align: center;
            padding: 10px;
            background: #ddd;
            margin-top: 30px;
        }
    </style>
</head>

<body>

    <div class="header">
        <h1>🎓 Student Portal</h1>
        <p>Welcome to your dashboard</p>
    </div>

    <div class="container">

        <div class="card">
            <h2>👋 Welcome</h2>
            <p>@ViewBag.Message</p>
            <p><b>Current time:</b> @ViewBag.Time</p>
        </div>

        <div class="card">
            <h2>📚 Features provided</h2>
            <ul>
                <li>View Courses</li>
                <li>Check Results</li>
                <li>Update</li>
            </ul>
        </div>

        <div class="card">
            <h2>🔗 Navigation</h2>
            <a href="/Home/About" class="btn">About us Page</a>
        </div>
 
    </div>

    <div class="footer">
        <p>Stu</p>
    </div>

</body>
</html>